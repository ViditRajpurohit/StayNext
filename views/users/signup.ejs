<% layout("/layouts/boilerplate") %>

<style>
    /* 1. Force remove any background from boilerplate */
    body {
        background: black !important;
        margin: 0;
        padding: 0;
        overflow: hidden; /* Prevents scrollbars during intro animation */
    }

    nav, footer { display: none !important; }

    /* 2. Background Image Configuration */
    .signup-bg {
        background-image: linear-gradient(rgba(0, 0, 0, 0.4), rgba(0, 0, 0, 0.4)), 
                          url('/images/bg-image-signup.jpg');
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        min-height: 100vh;
        width: 100%;
    }

    /* Zoom Effect for Intro Text */
    .text-grow-animation {
        transform: scale(100);
        opacity: 0;
        transition: transform 2s ease-in, opacity 1.5s ease-in;
    }
</style>

<div id="first-time-loader" class="fixed inset-0 z-[10005] bg-black hidden items-center justify-center overflow-hidden">
    <img src="/images/IntroImage.png" class="absolute inset-0 w-full h-full object-cover opacity-60">
    
    <div id="loader-content" class="relative z-10 text-center transition-all duration-1000">
        <h2 class="text-white tracking-[0.4em] font-light mb-4 text-sm">WELCOME</h2>
        <div id="brand-text" class="flex flex-col items-center">
            <h1 class="text-white text-7xl font-bold tracking-tighter">STAY</h1>
            <h1 class="text-rose-500 text-7xl font-bold tracking-tighter">NEST</h1>
        </div>
        <p class="text-gray-300 italic mt-6 text-sm">Your perfect home, everywhere you go.</p>
    </div>
</div>

<div id="signup-content" class="signup-bg opacity-0 transition-opacity duration-1000 flex items-center justify-center w-full min-h-screen fixed inset-0">
    
    <div class="w-full max-w-sm h-fit p-6 md:p-8 mx-4 bg-white/5 backdrop-blur-3xl border border-white/20 rounded-[2.5rem] shadow-2xl flex flex-col gap-5">
        
        <div class="text-center">
            <h2 class="text-2xl md:text-3xl font-bold text-white mb-1 tracking-tight">Create Account</h2>
            <p class="text-gray-200 text-[10px] md:text-xs font-light">Join our global community of travelers.</p>
        </div>
        
        <form action="/signup" method="POST" class="space-y-4 flex flex-col justify-center" novalidate id="signupForm">
            <div class="relative">
                <label class="block text-[9px] font-bold text-gray-300 uppercase tracking-widest mb-1 ml-1">Full Name</label>
                <input type="text" name="name" required placeholder="Vidit Rajpurohit" 
                       class="peer w-full bg-white/10 border border-white/10 rounded-2xl p-3 text-white text-sm placeholder:text-gray-400 focus:outline-none focus:border-rose-500 focus:bg-white/20 transition-all h-10">
            </div>

            <div class="relative">
                <label class="block text-[9px] font-bold text-gray-300 uppercase tracking-widest mb-1 ml-1">Email Address</label>
                <input type="email" name="email" required placeholder="hello@gmail.com"
                       class="peer w-full bg-white/10 border border-white/10 rounded-2xl p-3 text-white text-sm placeholder:text-gray-400 focus:outline-none focus:border-rose-500 focus:bg-white/20 transition-all h-10">
            </div>

            <div class="relative">
                <label class="block text-[9px] font-bold text-gray-300 uppercase tracking-widest mb-1 ml-1">Password</label>
                <input type="password" name="password" required minlength="8" placeholder="••••••••"
                       class="peer w-full bg-white/10 border border-white/10 rounded-2xl p-3 text-white text-sm placeholder:text-gray-400 focus:outline-none focus:border-rose-500 focus:bg-white/20 transition-all h-10">
            </div>

            <button class="w-full bg-rose-500 hover:bg-rose-600 text-white font-bold py-2.5 rounded-xl shadow-lg transform active:scale-95 transition duration-300 mt-2">
                Continue
            </button>
        </form>

        <div class="pt-4 border-t border-white/10 text-center">
            <a href="/login" class="inline-flex items-center text-white text-xs font-medium hover:text-rose-400 transition group">
                Already have an account? 
                <span class="ml-2 transform group-hover:translate-x-1 transition-transform duration-300">
                    <i class="fa-solid fa-arrow-right"></i>
                </span>
            </a>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const loader = document.getElementById('first-time-loader');
        const brandText = document.getElementById('brand-text');
        const signupContent = document.getElementById('signup-content');

        // 1. Ensure loader is visible and flexed immediately
        loader.classList.remove('hidden');
        loader.classList.add('flex');
        
        // Ensure body doesn't scroll during the intro
        document.body.style.overflow = 'hidden';

        // 2. Start the animation sequence
        setTimeout(() => {
            // Triggers the scale and opacity transition defined in your CSS
            brandText.classList.add('text-grow-animation');

            setTimeout(() => {
                // Fades out the entire black loader overlay
                loader.style.opacity = '0';
                
                // Fades in the actual signup form
                signupContent.classList.remove('opacity-0');
                
                // Final Cleanup: Remove from view and restore scrolling
                setTimeout(() => { 
                    loader.style.display = 'none'; 
                    document.body.style.overflow = 'auto'; 
                }, 1000);
            }, 1500);
        }, 1000); 
    });
</script>