<% layout("/layouts/boilerplate") %>

<style>
    /* 1. Standard StayNest UI reset */
    nav, footer { display: none !important; }

    body {
        background: black !important;
        margin: 0;
        padding: 0;
        overflow: hidden; /* Prevents accidental scrolling */
    }

    .verify-bg {
        background-image: linear-gradient(rgba(0, 0, 0, 0.4), rgba(0, 0, 0, 0.4)), 
                          url('/images/IntroImage.png'); 
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        min-height: 100vh;
        width: 100%;
    }
</style>

<div class="verify-bg flex items-center justify-center w-full min-h-screen fixed inset-0">
    
    <div class="w-full h-auto max-w-sm p-6 mx-4 bg-white/5 backdrop-blur-3xl border border-white/20 rounded-[2.5rem] shadow-2xl flex flex-col">
        
        <% if(success && success.length) { %>
            <div class="mb-4 p-2 rounded-xl bg-emerald-500/20 border border-emerald-500/40 text-emerald-400 text-[10px] font-medium text-center animate-pulse">
                <i class="fa-solid fa-circle-check mr-2"></i><%= success %>
            </div>
        <% } %>

        <% if(error && error.length) { %>
            <div class="mb-4 p-2 rounded-xl bg-rose-500/20 border border-rose-500/40 text-rose-400 text-[10px] font-medium text-center">
                <i class="fa-solid fa-circle-exclamation mr-2"></i><%= error %>
            </div>
        <% } %>
        
        <div class="text-center mb-6">
            <div class="mb-3 inline-flex items-center justify-center w-10 h-10 rounded-full bg-rose-500/20 text-rose-500">
                <i class="fa-solid fa-envelope-open-text text-xl"></i>
            </div>
            <h2 class="text-xl font-bold text-white mb-1 tracking-tight">Verify Email</h2>
            <p class="text-gray-300 text-[10px] font-light px-6 leading-relaxed">
                Enter the 6-digit code sent to your inbox.
            </p>
        </div>
        
        <form action="/verify" method="POST" class="space-y-6 flex flex-col justify-center" novalidate>
            
            <input type="hidden" name="email" value="<%= typeof email !== 'undefined' ? email : '' %>">

            <div class="relative group">
                <label class="block text-[9px] font-bold text-gray-400 uppercase tracking-widest mb-2 text-center">Verification Code</label>
                
                <input type="text" 
                       name="verificationCode" 
                       required 
                       maxlength="6" 
                       placeholder="000000"
                       pattern="\d{6}"
                       class="w-full bg-white/10 border border-white/10 rounded-xl p-3 text-white text-center text-3xl font-mono tracking-[0.4em] placeholder-white/20 focus:outline-none focus:border-rose-500 focus:bg-white/20 transition-all">
                
                <p class="mt-3 text-center text-[10px] text-gray-400">
                    Didn't received code? 
                    <a href="/resend-code?email=<%= email %>" class="text-rose-400 hover:text-rose-300 font-bold underline underline-offset-4 transition">Resend</a>
                </p>
            </div>

            <button class="w-full bg-rose-500 hover:bg-rose-600 text-white text-sm font-bold py-3.5 rounded-xl shadow-lg transform active:scale-95 transition duration-300">
                Verify & Continue
            </button>
        </form>

        <div class="mt-6 pt-4 border-t border-white/10 text-center">
            <a href="/signup" class="inline-flex items-center text-white text-[10px] font-medium hover:text-rose-400 transition group">
                <span class="mr-2 transform group-hover:-translate-x-1 transition-transform duration-300">
                    <i class="fa-solid fa-arrow-left"></i>
                </span>
                Back to Signup
            </a>
        </div>
    </div>
</div>