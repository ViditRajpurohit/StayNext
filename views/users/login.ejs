<% layout("/layouts/boilerplate") %>

<style>
    /* 1. Force removal of default layout elements */
    nav, footer { display: none !important; }

    body {
        background: black !important;
        margin: 0;
        padding: 0;
        overflow: hidden; 
    }

    /* 2. Using IntroImage.png as the background to match Signup */
    .login-bg {
        background-image: linear-gradient(rgba(0, 0, 0, 0.4), rgba(0, 0, 0, 0.4)), 
                          url('/images/IntroImage.png'); 
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        min-height: 100vh;
        width: 100%;
    }
</style>

<div class="login-bg flex items-center justify-center w-full min-h-screen fixed inset-0">
    
    <div class="w-full max-w-sm h-fit p-6 md:p-8 mx-4 bg-white/5 backdrop-blur-3xl border border-white/20 rounded-[2.5rem] shadow-2xl flex flex-col gap-5">
        
        <div class="text-center">
            <h2 class="text-2xl md:text-3xl font-bold text-white mb-1 tracking-tight">Welcome Back</h2>
            <p class="text-gray-200 text-[10px] md:text-xs font-light">Login to continue your journey.</p>
        </div>
        
        <form action="/login" method="POST" class="space-y-4 flex flex-col justify-center" novalidate>
            <div class="relative">
                <label class="block text-[9px] font-bold text-gray-300 uppercase tracking-widest mb-2 ml-1">Email Address</label>
                <input type="email" name="email" required placeholder="viditrajpurohit27@gmail.com"
                       class="peer w-full bg-white/10 border border-white/10 rounded-2xl p-3 text-white text-sm placeholder:text-white/30 focus:outline-none focus:border-rose-500 focus:bg-white/20 transition-all h-10">
            </div>

            <div class="relative">
                <div class="flex justify-between items-center mb-2 ml-1">
                    <label class="block text-[9px] font-bold text-gray-300 uppercase tracking-widest">Password</label>
                    <a href="/forgot-password" class="text-[9px] font-bold text-rose-400 uppercase tracking-widest hover:text-rose-300 transition-colors">
                        Forgot Password?
                    </a>
                </div>
                <input type="password" name="password" required placeholder="••••••••"
                       class="peer w-full bg-white/10 border border-white/10 rounded-2xl p-3 text-white text-sm placeholder:text-white/30 focus:outline-none focus:border-rose-500 focus:bg-white/20 transition-all h-10">
            </div>

            <button class="w-full bg-rose-500 hover:bg-rose-600 text-white font-bold py-2.5 rounded-xl shadow-lg transform active:scale-95 transition duration-300 mt-2">
                Log In
            </button>
        </form>

        <div class="pt-4 border-t border-white/10 text-center">
            <a href="/signup" class="inline-flex items-center text-white text-xs font-medium hover:text-rose-400 transition group">
                Don't have an account? 
                <span class="ml-2 transform group-hover:translate-x-1 transition-transform duration-300">
                    <i class="fa-solid fa-arrow-right"></i>
                </span>
            </a>
        </div>
    </div>
</div>