<% layout("/layouts/boilerplate") %>

<div class="max-w-lg mx-auto px-4 py-8">
    <div class="mb-6 text-center">
        <h1 class="text-2xl font-bold text-gray-900">Create a New Listing</h1>
        <p class="text-sm text-gray-600">Share your amazing place with the world.</p>
    </div>

    <div class="bg-white border border-gray-200 rounded-2xl p-6 shadow-sm">
        <form method="POST" action="/listings" class="space-y-4 needs-validation" id="listingForm" enctype="multipart/form-data" novalidate>
            
            <!-- Title -->
            <div class="validation-container group"> <!-- Localized group -->
                <label class="block text-sm font-semibold mb-1 text-gray-700">Title</label>
                <input name="listing[title]" type="text" placeholder="Enter a catchy title" required
                    class="peer w-full px-3 py-2 text-sm rounded-lg border border-gray-300 focus:ring-2 focus:ring-rose-500 outline-none transition-all
                    group-[.was-validated]:invalid:border-red-500 group-[.was-validated]:valid:border-green-500">
                <p class="hidden group-[.was-validated]:peer-valid:block text-[11px] text-green-600 mt-1 font-medium">Title looks good!</p>
                <p class="hidden group-[.was-validated]:peer-invalid:block text-[11px] text-red-600 mt-1">Please enter a catchy title.</p>
            </div>

            <!-- Description -->
            <div class="validation-container group">
                <label class="block text-sm font-semibold mb-1 text-gray-700">Description</label>
                <textarea name="listing[description]" rows="3" placeholder="Describe what makes your place special" required
                    class="peer w-full px-3 py-2 text-sm rounded-lg border border-gray-300 focus:ring-2 focus:ring-rose-500 outline-none transition-all
                    group-[.was-validated]:invalid:border-red-500 group-[.was-validated]:valid:border-green-500"></textarea>
                <p class="hidden group-[.was-validated]:peer-valid:block text-[11px] text-green-600 mt-1 font-medium">Description looks perfect!</p>
                <p class="hidden group-[.was-validated]:peer-invalid:block text-[11px] text-red-600 mt-1">Please write a short description.</p>
            </div>

            <!-- Image Upload -->
            
            
            <div class="validation-container group">
                <label class="block text-sm font-semibold mb-1 text-gray-700">Image Upload</label>
                <input name="listing[image]" type="file" required
                    class="peer w-full px-3 py-2 text-sm rounded-lg border border-gray-300 focus:ring-2 focus:ring-rose-500 outline-none transition-all
                    group-[.was-validated]:invalid:border-red-500 group-[.was-validated]:valid:border-green-500">
                <p class="hidden group-[.was-validated]:peer-invalid:block text-[11px] text-red-600 mt-1">Please provide a valid image link.</p>
            </div>

            <div class="grid grid-cols-2 gap-4">
                <!-- Price -->
                <div class="validation-container group">
                    <label class="block text-sm font-semibold mb-1 text-gray-700">Price</label>
                    <div class="relative">
                        <span class="absolute left-3 top-2 text-gray-500 text-sm">₹</span>
                        <input name="listing[price]" type="number" placeholder="1200" required min="1"
                            class="peer w-full pl-7 pr-3 py-2 text-sm rounded-lg border border-gray-300 focus:ring-2 focus:ring-rose-500 outline-none transition-all
                            group-[.was-validated]:invalid:border-red-500 group-[.was-validated]:valid:border-green-500">
                        <p class="hidden group-[.was-validated]:peer-valid:block text-[11px] text-green-600 mt-1 font-medium">Price is set!</p>
                        <p class="hidden group-[.was-validated]:peer-invalid:block text-[11px] text-red-600 mt-1">Enter a valid price.</p>
                    </div>
                </div>
                <!-- Country -->
                <div class="validation-container group">
                    <label class="block text-sm font-semibold mb-1 text-gray-700">Country</label>
                    <input name="listing[country]" type="text" placeholder="India" required
                        class="peer w-full px-3 py-2 text-sm rounded-lg border border-gray-300 focus:ring-2 focus:ring-rose-500 outline-none transition-all
                        group-[.was-validated]:invalid:border-red-500 group-[.was-validated]:valid:border-green-500">
                    <p class="hidden group-[.was-validated]:peer-valid:block text-[11px] text-green-600 mt-1 font-medium">Country looks valid!</p>
                    <p class="hidden group-[.was-validated]:peer-invalid:block text-[11px] text-red-600 mt-1">Country is required.</p>
                </div>
            </div>

            <!-- Location -->
            <div class="validation-container group">
                <label class="block text-sm font-semibold mb-1 text-gray-700">Location</label>
                <input name="listing[location]" type="text" placeholder="Jaipur, Rajasthan" required
                    class="peer w-full px-3 py-2 text-sm rounded-lg border border-gray-300 focus:ring-2 focus:ring-rose-500 outline-none transition-all
                    group-[.was-validated]:invalid:border-red-500 group-[.was-validated]:valid:border-green-500">
                <p class="hidden group-[.was-validated]:peer-valid:block text-[11px] text-green-600 mt-1 font-medium">Location is set!</p>
                <p class="hidden group-[.was-validated]:peer-invalid:block text-[11px] text-red-600 mt-1">Please enter the location.</p>
            </div>

            <button type="submit" class="w-full bg-rose-500 text-white font-bold py-2.5 px-4 rounded-lg transition-all duration-300 hover:bg-rose-600 hover:scale-[1.02] active:scale-[0.95]">
                Create Listing
            </button>
        </form>
    </div>
</div>

<script>
    const form = document.getElementById('listingForm');
    const inputs = form.querySelectorAll('input, textarea');
    const preloader = document.getElementById('preloader');
    const body = document.body;

    // --- Real-time Validation Logic ---
    inputs.forEach(input => {
        ['blur', 'input'].forEach(eventType => {
            input.addEventListener(eventType, () => {
                const container = input.closest('.validation-container');
                if (container && (input.value.length > 0 || eventType === 'blur')) {
                    container.classList.add('was-validated');
                }
            });
        });
    });

    // --- Submit Logic (Validation + Loader) ---
    form.addEventListener('submit', event => {
        if (!form.checkValidity()) {
            // 1. If form is INVALID: stop submission and show errors
            event.preventDefault();
            event.stopPropagation();
            document.querySelectorAll('.validation-container').forEach(c => c.classList.add('was-validated'));
        } else {
            // 2. If form is VALID: Show the spinning loader
            preloader.style.display = 'flex';
            preloader.classList.remove('opacity-0');
            body.classList.add('loading');
            
            // Update the text so the user knows why it's taking time
            const loadingText = preloader.querySelector('p');
            if (loadingText) {
                loadingText.innerText = "Publishing your listing to the cloud...";
            }
        }
    }, false);
</script>