<% layout("/layouts/boilerplate") %>

<div class="max-w-lg mx-auto px-4 py-8">
    <!-- Header -->
    <div class="mb-6">
        <h1 class="text-2xl font-bold text-gray-800">Edit Your Listing</h1>
        <p class="text-sm text-gray-500">Update the details of your property below.</p>
    </div>

    <!-- Form Container -->
    <div class="bg-white border border-gray-200 rounded-2xl p-6 shadow-sm">
        <form method="POST" action="/listings/<%= listing._id %>?_method=PUT" class="space-y-4" enctype="multipart/form-data">
            
            <!-- Title -->
            <div>
                <label class="block text-sm font-semibold mb-1 text-gray-700">Title</label>
                <input name="listing[title]" type="text" value="<%= listing.title %>" required
                    class="w-full px-3 py-2 text-sm rounded-lg border border-gray-300 focus:ring-2 focus:ring-rose-500 focus:border-rose-500 outline-none transition-all">
            </div>

            <!-- Description -->
            <div>
                <label class="block text-sm font-semibold mb-1 text-gray-700">Description</label>
                <textarea name="listing[description]" rows="4" required
                    class="w-full px-3 py-2 text-sm rounded-lg border border-gray-300 focus:ring-2 focus:ring-rose-500 focus:border-rose-500 outline-none transition-all"><%= listing.description %></textarea>
            </div>

            <!-- Image URL -->
            <div>
        <label class="block text-sm font-semibold mb-1 text-gray-700">Original Listing Image</label>
        <div class="mb-3">
            <img src="<%= listing.image.url %>" class="w-40 h-24 object-cover rounded-lg border border-gray-200">
        </div>
        
        <label class="block text-sm font-semibold mb-1 text-gray-700">Upload New Image</label>
        <input name="listing[image]" type="file" 
            class="w-full px-3 py-2 text-sm rounded-lg border border-gray-300 focus:ring-2 focus:ring-rose-500 focus:border-rose-500 outline-none transition-all">
    </div>

            <!-- Price & Country Row -->
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm font-semibold mb-1 text-gray-700">Price</label>
                    <div class="relative">
                        <span class="absolute left-3 top-2 text-gray-500 text-sm">₹</span>
                        <input name="listing[price]" type="number" value="<%= listing.price %>" required
                            class="w-full pl-7 pr-3 py-2 text-sm rounded-lg border border-gray-300 focus:ring-2 focus:ring-rose-500 focus:border-rose-500 outline-none transition-all">
                    </div>
                </div>
                <div>
                    <label class="block text-sm font-semibold mb-1 text-gray-700">Country</label>
                    <input name="listing[country]" type="text" value="<%= listing.country %>" required
                        class="w-full px-3 py-2 text-sm rounded-lg border border-gray-300 focus:ring-2 focus:ring-rose-500 focus:border-rose-500 outline-none transition-all">
                </div>
            </div>

            <!-- Location -->
            <div>
                <label class="block text-sm font-semibold mb-1 text-gray-700">Location</label>
                <input name="listing[location]" type="text" value="<%= listing.location %>" required
                    class="w-full px-3 py-2 text-sm rounded-lg border border-gray-300 focus:ring-2 focus:ring-rose-500 focus:border-rose-500 outline-none transition-all">
            </div>

            <!-- Action Buttons -->
            <div class="flex items-center gap-3 pt-4">
                <a href="/listings/<%= listing._id %>" 
                   class="flex-1 text-center bg-white border border-gray-300 text-gray-700 text-sm font-bold py-2.5 rounded-lg 
              transition-all duration-300 ease-in-out 
              hover:border-gray-900 hover:text-gray-900 hover:shadow-sm hover:-translate-y-0.5">
                    Cancel
                </a>
                <button type="submit" 
                    class="flex-1 bg-rose-500 border border-rose-500 text-white font-bold py-2.5 rounded-lg shadow-md 
                   transition-all duration-300 ease-in-out 
                   hover:bg-white hover:text-rose-500 hover:shadow-[0_10px_20px_rgba(244,63,94,0.3)] hover:-translate-y-1 
                   active:scale-95">
                    Update Listing
                </button>
            </div>

        </form>
    </div>
</div>