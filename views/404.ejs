<% layout("/layouts/boilerplate") %>
<div class="max-w-md mx-auto text-center py-20 px-4">
    <div class="relative inline-block">
        <h1 class="text-9xl font-black text-gray-100">404</h1>
        <p class="absolute inset-0 flex items-center justify-center text-2xl font-bold text-rose-500 mt-4">
            Oops! Lost?
        </p>
    </div>
    <h2 class="text-xl font-semibold text-gray-800 mt-6">Page Not Found</h2>
    <p class="text-gray-500 mt-2 mb-8">
        The listing or page you are looking for has been moved or doesn't exist.
    </p>
    <a href="/listings" 
       class="inline-block bg-rose-500 text-white px-8 py-3 rounded-xl font-bold shadow-lg hover:bg-rose-600 transition-all active:scale-95">
        Back to Listings
    </a>
</div>